/* ══════════════════════════════════════════════════
   DRAW SVG
══════════════════════════════════════════════════ */
function draw(){
  const svg=document.getElementById('msv');
  svg.setAttribute('viewBox','0 0 800 530');
  svg.innerHTML='';

  const isDark=(document.documentElement.getAttribute('data-theme')||'dark')==='dark';

  /* defs */
  const defs=$s('defs');
  defs.innerHTML=`
    <filter id="glow" x="-60%" y="-60%" width="220%" height="220%">
      <feGaussianBlur stdDeviation="4" result="b"/>
      <feMerge><feMergeNode in="b"/><feMergeNode in="SourceGraphic"/></feMerge>
    </filter>
    <filter id="oglow" x="-60%" y="-60%" width="220%" height="220%">
      <feGaussianBlur stdDeviation="5" result="b"/>
      <feMerge><feMergeNode in="b"/><feMergeNode in="SourceGraphic"/></feMerge>
    </filter>
    <filter id="rglow" x="-70%" y="-70%" width="240%" height="240%">
      <feGaussianBlur stdDeviation="6" result="b"/>
      <feMerge><feMergeNode in="b"/><feMergeNode in="SourceGraphic"/></feMerge>
    </filter>
    <filter id="shatter" x="-80%" y="-80%" width="260%" height="260%">
      <feTurbulence type="fractalNoise" baseFrequency=".85" numOctaves="4" result="n"/>
      <feDisplacementMap in="SourceGraphic" in2="n" scale="9" xChannelSelector="R" yChannelSelector="G"/>
    </filter>
    <radialGradient id="nodegrad" cx="40%" cy="35%" r="65%">
      <stop offset="0%" stop-color="${isDark?'#1a3050':'#ddeeff'}"/>
      <stop offset="100%" stop-color="${isDark?'#0a1828':'#c8daf0'}"/>
    </radialGradient>
    <radialGradient id="swgrad" cx="40%" cy="35%" r="65%">
      <stop offset="0%" stop-color="${isDark?'#1a2840':'#dde8f8'}"/>
      <stop offset="100%" stop-color="${isDark?'#0a1520':'#c0d0e8'}"/>
    </radialGradient>
  `;
  svg.appendChild(defs);

  if(topo==='ring'){
    const hint=$s('text');
    sa(hint,{x:390,y:270,'text-anchor':'middle',fill:isDark?'rgba(255,106,0,.15)':'rgba(200,74,0,.2)',
      'font-size':11,'font-family':'Share Tech Mono,monospace'});
    hint.textContent='↻ CLOCKWISE'; svg.appendChild(hint);
  }

  /* ── LINKS ── */
  const lg=$s('g');
  links.forEach(lk=>{
    const na=getNode(lk.a),nb=getNode(lk.b); if(!na||!nb) return;
    const cut=cutSet.has(lid(lk.a,lk.b));
    const swDead=switchBroken&&(lk.a==='SW'||lk.b==='SW');
    const isMitmLink=mitm&&(lk.a==='SW'||lk.b==='SW');

    const line=$s('line');
    const stroke=cut||swDead ? cv('--red')
                : isMitmLink ? cv('--purple')
                : lk.bus     ? (isDark?'#1e4a8a':'#88aacc')
                : lk.ring    ? (isDark?'#1a3a70':'#99bbdd')
                :               (isDark?'#152535':'#b8cce0');
    sa(line,{x1:na.x,y1:na.y,x2:nb.x,y2:nb.y,
      stroke,
      'stroke-width': lk.bus?5: lk.ring?2.5:2,
      'stroke-linecap':'round',
      'stroke-dasharray': cut||swDead?'6,5':'0',
      opacity: cut||swDead?.4:1
    });
    if(isMitmLink&&!cut) line.setAttribute('filter','url(#glow)');
    lg.appendChild(line);

    /* ring cable hover area → scissors */
    if(topo==='ring'&&!cut){
      const hit=$s('line');
      sa(hit,{x1:na.x,y1:na.y,x2:nb.x,y2:nb.y,stroke:'transparent','stroke-width':24});
      hit.style.cursor='crosshair';

      hit.addEventListener('mouseenter',(e)=>{
        removeHoverSc();
        const sc=$s('text');
        sa(sc,{x:0,y:0,'text-anchor':'middle','font-size':22,id:'hsc',
          style:'pointer-events:none;filter:drop-shadow(0 0 5px #ff2244);'});
        sc.textContent='✂️'; svg.appendChild(sc);
        hoverScEl=sc;
        line.setAttribute('stroke',cv('--orange'));
        line.setAttribute('stroke-width','3.5');
        showTip(e,'CLICK TO SEVER CABLE');
        doneTask(3);
      });
      hit.addEventListener('mousemove',(e)=>{
        if(hoverScEl){
          const r=document.getElementById('svgwrap').getBoundingClientRect();
          const px=(e.clientX-r.left)/r.width*800;
          const py=(e.clientY-r.top)/r.height*530;
          hoverScEl.setAttribute('x',px+12);
          hoverScEl.setAttribute('y',py+12);
        }
        showTip(e,'CLICK TO SEVER CABLE');
      });
      hit.addEventListener('mouseleave',()=>{
        removeHoverSc();
        line.setAttribute('stroke',isDark?'#1a3a70':'#99bbdd');
        line.setAttribute('stroke-width','2.5');
        hideTip();
      });
      hit.addEventListener('click',()=>cutCable(lk.a,lk.b,na,nb));
      lg.appendChild(hit);
    }
  });
  svg.appendChild(lg);

  /* ── NODES ── */
  const ng=$s('g');
  nodes.forEach(n=>{
    if(n.type==='bus') return;
    const g=$s('g');
    if(n.type==='switch')    drawSwitch(g,n,isDark);
    else if(n.type==='term') drawTerm(g,n);
    else                     drawPC(g,n,isDark);
    ng.appendChild(g);
  });
  svg.appendChild(ng);
}

/* ─ SWITCH ─ */
function drawSwitch(g,n,dark){
  const broken=switchBroken, isMitm=mitm&&!broken;
  const r=$s('rect');
  sa(r,{x:n.x-50,y:n.y-22,width:100,height:44,rx:3,
    fill:'url(#swgrad)',
    stroke: broken?cv('--red'): isMitm?cv('--purple'): cv('--orange'),
    'stroke-width': broken?1.5:2,
    'stroke-dasharray': broken?'5,3':'0',
    opacity: broken?.5:1
  });
  if(broken) r.setAttribute('filter','url(#shatter)');
  if(isMitm) r.setAttribute('filter','url(#glow)');
  g.appendChild(r);

  /* corner brackets — cyberpunk style */
  if(!broken){
    [[-50,-22],[ 42,-22],[-50,14],[ 42,14]].forEach(([ox,oy],i)=>{
      const bx=n.x+ox+( i%2===0 ? 0 : 6);
      const by=n.y+oy+( i<2     ? 0 : 2);
      const lh=$s('line'), lv=$s('line');
      const sx=i%2===0?1:-1, sy=i<2?1:-1;
      sa(lh,{x1:bx,y1:by,x2:bx+sx*10,y2:by,stroke:cv('--orange-dim'),'stroke-width':1.5,'stroke-linecap':'round'});
      sa(lv,{x1:bx,y1:by,x2:bx,y2:by+sy*8,stroke:cv('--orange-dim'),'stroke-width':1.5,'stroke-linecap':'round'});
      g.appendChild(lh); g.appendChild(lv);
    });
  }

  const lbl=$s('text');
  sa(lbl,{x:n.x,y:n.y+5,'text-anchor':'middle',
    fill: broken?cv('--red'): isMitm?cv('--purple'): cv('--orange'),
    'font-family':'Share Tech Mono,monospace','font-size':11.5,'font-weight':700,
    'letter-spacing':'.06em'
  });
  if(broken) lbl.setAttribute('filter','url(#rglow)');
  lbl.textContent=broken?'DEAD': isMitm?'[MitM]':'SWITCH';
  g.appendChild(lbl);

  if(!broken){
    g.style.cursor='pointer';
    g.addEventListener('mouseenter',(e)=>{
      if(switchBroken) return;
      doneTask(3);
      removeHammer();
      const svg=document.getElementById('msv');
      const h=$s('text');
      sa(h,{x:n.x+60,y:n.y-10,'font-size':28,id:'hammer-ico',
        style:'pointer-events:none;',
        transform:`rotate(-35,${n.x+60},${n.y-10})`
      });
      h.textContent='🔨'; svg.appendChild(h);
      let ang=-35, dir=1;
      h._bob=setInterval(()=>{
        if(!document.getElementById('hammer-ico')){ clearInterval(h._bob); return; }
        ang+=dir*2.5; if(Math.abs(ang+35)>10) dir=-dir;
        h.setAttribute('transform',`rotate(${ang},${n.x+60},${n.y-10})`);
      },35);
      showTip(e,'🔨 CLICK TO SMASH SWITCH');
    });
    g.addEventListener('mouseleave',()=>{ removeHammer(); hideTip(); });
    g.addEventListener('click',()=>{ if(topo==='star'&&!switchBroken) smashSwitch(n); });
  }
}

/* ─ TERMINATOR ─ */
function drawTerm(g,n){
  const r=$s('rect');
  sa(r,{x:n.x-13,y:n.y-13,width:26,height:26,rx:2,
    fill:cv('--surface2'), stroke:cv('--red'),'stroke-width':1.5});
  g.appendChild(r);
  const t=$s('text');
  sa(t,{x:n.x,y:n.y+5,'text-anchor':'middle',fill:cv('--red'),
    'font-size':10,'font-family':'Share Tech Mono,monospace'});
  t.textContent='T'; g.appendChild(t);
}

/* ─ PC NODE ─ */
function drawPC(g,n,dark){
  const isSrc=src===n.id, isDst=dst===n.id;
  const stroke=isSrc?cv('--orange'):isDst?cv('--green'):cv('--node-stroke');
  const fill=isSrc?`rgba(255,106,0,.12)`:isDst?`rgba(0,255,136,.1)`:  'url(#nodegrad)';

  const c=$s('circle');
  sa(c,{cx:n.x,cy:n.y,r:26,fill,stroke,'stroke-width':isSrc||isDst?2.5:1.5});
  if(isSrc) sa(c,{filter:'url(#oglow)'});
  else if(isDst) sa(c,{filter:'url(#glow)'});
  g.appendChild(c);

  /* hexagonal accent ring */
  const hex=$s('circle');
  sa(hex,{cx:n.x,cy:n.y,r:30,fill:'none',
    stroke:isSrc?cv('--orange-dim'):isDst?cv('--green-dim'):cv('--border'),
    'stroke-width':.8,'stroke-dasharray':isSrc||isDst?'3,3':'4,5',opacity:.7});
  g.appendChild(hex);

  const ico=$s('text');
  sa(ico,{x:n.x,y:n.y+6,'text-anchor':'middle','dominant-baseline':'middle','font-size':14});
  ico.textContent='⬡'; g.appendChild(ico);

  const lbl=$s('text');
  sa(lbl,{x:n.x,y:n.y+40,'text-anchor':'middle',
    fill:isSrc?cv('--orange'):isDst?cv('--green'):cv('--muted'),
    'font-size':10,'font-family':'Share Tech Mono,monospace','font-weight':700,
    'letter-spacing':'.06em'
  });
  lbl.textContent=n.label||n.id; g.appendChild(lbl);

  if(isSrc||isDst){
    const tag=$s('text');
    sa(tag,{x:n.x,y:n.y-36,'text-anchor':'middle',
      fill:isSrc?cv('--orange'):cv('--green'),
      'font-size':8,'font-family':'Share Tech Mono,monospace','font-weight':700,'letter-spacing':'.1em'
    });
    tag.textContent=isSrc?'[SRC]':'[DST]'; g.appendChild(tag);
  }

  g.style.cursor='pointer';
  g.addEventListener('click',()=>selectNode(n.id));
  g.addEventListener('mouseenter',()=>{ if(!isSrc&&!isDst){ c.setAttribute('stroke',cv('--orange-dim')); c.setAttribute('filter','url(#oglow)'); }});
  g.addEventListener('mouseleave',()=>{ if(!isSrc&&!isDst){ c.setAttribute('stroke',cv('--node-stroke')); c.removeAttribute('filter'); }});
}

/* ══════════════════════════════════════════════════
   CUT CABLE
══════════════════════════════════════════════════ */
function cutCable(a,b,na,nb){
  removeHoverSc(); hideTip();
  cutSet.add(lid(a,b)); draw(); updateStatus();
  addLog(`> ✂ ${a} ↔ ${b} — SEVERED`,'fail');
  addLog(`> RING BROKEN — TOTAL FAILURE`,'fail');
  doneTask(4);

  const svg=document.getElementById('msv');
  const mx=(na.x+nb.x)/2, my=(na.y+nb.y)/2;

  /* X sparks */
  [[mx-10,my-10,mx+10,my+10],[mx+10,my-10,mx-10,my+10]].forEach(([x1,y1,x2,y2])=>{
    const xl=$s('line');
    sa(xl,{x1,y1,x2,y2,stroke:cv('--red'),'stroke-width':3,'stroke-linecap':'round',filter:'url(#rglow)'});
    svg.appendChild(xl);
    let op=1; const f=setInterval(()=>{ op-=.03; xl.setAttribute('opacity',Math.max(0,op)); if(op<=0){clearInterval(f);xl.remove();} },35);
  });

  /* floating label */
  const st=$s('text');
  sa(st,{x:mx,y:my-14,'text-anchor':'middle',fill:cv('--red'),'font-size':10,'font-weight':700,
    'font-family':'Share Tech Mono,monospace',filter:'url(#rglow)','letter-spacing':'.1em'});
  st.textContent='SEVERED'; svg.appendChild(st);
  let sy=my-14,sop=1;
  const sf=setInterval(()=>{ sop-=.02; sy-=.5; st.setAttribute('y',sy); st.setAttribute('opacity',Math.max(0,sop)); if(sop<=0){clearInterval(sf);st.remove();} },35);
}

/* ══════════════════════════════════════════════════
   SMASH SWITCH
══════════════════════════════════════════════════ */
function smashSwitch(n){
  removeHammer(); hideTip(); doneTask(4);
  const svg=document.getElementById('msv');
  const h=$s('text');
  sa(h,{x:n.x+12,y:n.y-44,'text-anchor':'middle','font-size':42,style:'pointer-events:none;'});
  h.textContent='🔨'; svg.appendChild(h);

  let frame=0;
  const slam=setInterval(()=>{
    frame++;
    const t=frame/14;
    const y=n.y-44+(44*t);
    const scale=1+0.6*(1-t);
    const rot=-38+38*t;
    h.setAttribute('y',y);
    h.setAttribute('transform',`scale(${scale}) rotate(${rot},${n.x+12},${y})`);
    if(frame>=14){
      clearInterval(slam);
      h.remove();
      spawnShatter(n.x,n.y);
      switchBroken=true;
      draw(); updateStatus();
      addLog(`> 💥 SWITCH DESTROYED — NETWORK DOWN`,'fail');
      addLog(`> ALL ${nodes.filter(x=>!x.type||x.type==='pc').length} NODES OFFLINE`,'fail');
      nodes.filter(x=>!x.type||x.type==='pc').forEach(x=>
        setTimeout(()=>flashNode(x.id,cv('--red')),Math.random()*380));
    }
  },18);
}

function spawnShatter(cx,cy){
  const svg=document.getElementById('msv');
  const parts=['◆','▲','●','✕','◉','▪'];
  for(let i=0;i<16;i++){
    const p=$s('text');
    const angle=Math.random()*Math.PI*2;
    const spd=50+Math.random()*90;
    const vx=Math.cos(angle)*spd, vy=Math.sin(angle)*spd;
    sa(p,{x:cx,y:cy,'font-size':8+Math.random()*12,'text-anchor':'middle',
      fill:[cv('--orange'),cv('--red'),cv('--yellow'),'#ffffff'][Math.floor(Math.random()*4)],
      style:'pointer-events:none;'});
    p.textContent=parts[Math.floor(Math.random()*parts.length)];
    svg.appendChild(p);
    let px=cx,py=cy,op=1,t=0;
    const pf=setInterval(()=>{
      t+=.04; op-=.03;
      px+=vx*.04; py+=vy*.04+t*2.5;
      p.setAttribute('x',px); p.setAttribute('y',py);
      p.setAttribute('opacity',Math.max(0,op));
      if(op<=0){clearInterval(pf);p.remove();}
    },18);
  }
  /* shockwave */
  const ring=$s('circle');
  sa(ring,{cx,cy,r:8,fill:'none',stroke:cv('--orange'),'stroke-width':3,opacity:.9,filter:'url(#oglow)'});
  svg.appendChild(ring);
  let rr=8,rop=.9;
  const rf=setInterval(()=>{ rr+=9; rop-=.06; ring.setAttribute('r',rr); ring.setAttribute('opacity',Math.max(0,rop)); if(rop<=0){clearInterval(rf);ring.remove();} },18);
}

/* ══════════════════════════════════════════════════
   SELECT NODE
══════════════════════════════════════════════════ */
function selectNode(id){
  if(!src){ src=id; setRV(`${id} → ...`); addLog(`> SRC: ${id}`,'orange'); doneTask(1); }
  else if(!dst&&id!==src){ dst=id; setRV(`${src} → ${dst}`); addLog(`> DST: ${id}`,'orange'); doneTask(2); }
  else { src=id; dst=null; setRV(`${id} → ...`); addLog(`> SRC: ${id}`,'orange'); }
  draw();
}

/* ══════════════════════════════════════════════════
   SEND PACKET
══════════════════════════════════════════════════ */
function sendPacket(){
  if(!src||!dst){ addLog('> ERROR: select SRC & DST first','warn'); return; }

  if(topo==='bus'){
    dosSent++;
    const inc=Math.max(2, DOS_INC - dosLoad/8);
    dosLoad=Math.min(100, dosLoad+inc);
    if(dosLoad>=DOS_WARN) dosColl++;
    updateGauge(); resetDecayTimer();
    if(dosLoad>=DOS_DEAD&&!dosDown){
      dosDown=true; dosDrop++;
      updateGauge(); draw(); updateStatus();
      addLog('> 💥 NETWORK OVERLOAD — DoS COMPLETE','fail');
      doneTask(3);
      nodes.filter(n=>!n.type||n.type==='pc').forEach(n=>setTimeout(()=>flashNode(n.id,cv('--red')),Math.random()*380));
      return;
    }
    if(dosLoad>=DOS_WARN){ addLog(`> COLLISION! Load: ${Math.round(dosLoad)}%`,'warn'); doneTask(3); }
    else addLog(`> SENT. Load: ${Math.round(dosLoad)}%`,'ok');
  }

  const def=DEFS[topo];
  const path=def.getPath(src,dst);
  if(!path){
    dosDrop++;
    addLog(`> FAIL: ${src} → ${dst} — no route`,'fail');
    if(topo==='ring')   addLog('> Ring severed.','fail');
    else if(topo==='bus'){ addLog('> Network overloaded.','fail'); updateGauge(); }
    else                  addLog('> Switch offline.','fail');
    showXon(dst); doneTask(4); return;
  }

  if(mitm&&topo==='star'){
    addLog(`> ${src} → [SWITCH captures] → ${dst}`,'mitm');
    animPkt([src,'SW'],()=>{
      addLog('> 🕵 PACKET INTERCEPTED',(mitm));
      flashSW();
      setTimeout(()=>animPkt(['SW',dst],()=>addLog(`> FORWARDED → ${dst}`,'mitm')),650);
    },true);
    return;
  }
  addLog(`> ${src} → ${dst}`,'ok');
  animPkt(path,()=>{ addLog(`> DELIVERED ✓`,'ok'); doneTask(2); },false);
}

/* ══════════════════════════════════════════════════
   ANIMATE PACKET
══════════════════════════════════════════════════ */
function animPkt(path, done, isMitm=false){
  const svg=document.getElementById('msv');
  const pts=path.map(id=>{ const n=getNode(id); return n?{x:n.x,y:n.y}:null; }).filter(Boolean);
  if(pts.length<2){ done&&done(); return; }

  const g=$s('g');
  const pColor=isMitm?cv('--purple'):cv('--orange');
  const c=$s('circle');
  sa(c,{r:9,fill:pColor,filter:'url(#oglow)',opacity:.95});
  /* trail */
  const trail=$s('circle');
  sa(trail,{r:13,fill:'none',stroke:pColor,'stroke-width':1.5,opacity:.3,filter:'url(#glow)'});
  const lbl=$s('text');
  sa(lbl,{x:0,y:0,'text-anchor':'middle','dominant-baseline':'middle','font-size':9,
    fill:cv('--bg'),'font-family':'Share Tech Mono,monospace','font-weight':700});
  lbl.textContent='PKT';
  g.appendChild(trail); g.appendChild(c); g.appendChild(lbl);
  g.setAttribute('transform',`translate(${pts[0].x},${pts[0].y})`);
  svg.appendChild(g);

  let seg=0;
  const segMs=topo==='bus'?Math.max(65,300-dosLoad*2):320;
  function step(){
    if(seg>=pts.length-1){ g.remove(); flashNode(path[path.length-1],isMitm?cv('--purple'):cv('--green')); done&&done(); return; }
    const from=pts[seg],to=pts[seg+1];
    const t0=performance.now();
    (function fr(now){
      const t=Math.min((now-t0)/segMs,1);
      const e=t<.5?2*t*t:1-Math.pow(-2*t+2,2)/2;
      g.setAttribute('transform',`translate(${from.x+(to.x-from.x)*e},${from.y+(to.y-from.y)*e})`);
      if(t<1) requestAnimationFrame(fr); else{ seg++; step(); }
    })(t0);
  }
  step();
}

function flashNode(id,color){
  const svg=document.getElementById('msv');
  const n=getNode(id); if(!n) return;
  const c=$s('circle');
  sa(c,{cx:n.x,cy:n.y,r:32,fill:color,opacity:.35,filter:'url(#glow)'});
  svg.appendChild(c);
  let op=.35; const f=setInterval(()=>{ op-=.04; c.setAttribute('opacity',Math.max(0,op)); if(op<=0){clearInterval(f);c.remove();} },35);
}

function flashSW(){
  const svg=document.getElementById('msv');
  const n=getNode('SW'); if(!n) return;
  const r=$s('rect');
  sa(r,{x:n.x-58,y:n.y-32,width:116,height:64,rx:4,fill:cv('--purple'),opacity:.22,filter:'url(#glow)'});
  svg.appendChild(r);
  let op=.22; const f=setInterval(()=>{ op-=.025; r.setAttribute('opacity',Math.max(0,op)); if(op<=0){clearInterval(f);r.remove();} },35);
}

function showXon(id){
  const svg=document.getElementById('msv');
  const n=getNode(id); if(!n) return;
  const t=$s('text');
  sa(t,{x:n.x,y:n.y-40,'text-anchor':'middle',fill:cv('--red'),'font-size':22,'font-weight':700,
    'font-family':'Share Tech Mono,monospace',filter:'url(#rglow)','letter-spacing':'.1em'});
  t.textContent='[ERR]'; svg.appendChild(t);
  let op=1; const f=setInterval(()=>{ op-=.022; t.setAttribute('opacity',Math.max(0,op)); if(op<=0){clearInterval(f);t.remove();} },35);
}

/* ══════════════════════════════════════════════════
   MITM
══════════════════════════════════════════════════ */
function toggleMitm(){
  if(switchBroken) return;
  mitm=!mitm;
  const btn=document.getElementById('mitm-btn');
  if(btn) btn.classList.toggle('mitm-on',mitm);
  draw(); updateStatus();
  addLog(mitm?'> 🕵 MitM ACTIVE — intercepting all traffic':'> MitM DISABLED',mitm?'mitm':'info');
}

/* ══════════════════════════════════════════════════
   BUS DECAY
══════════════════════════════════════════════════ */
function startDecay(){
  clearInterval(dosDecayTimer);
  dosDecayTimer=setInterval(()=>{
    if(topo!=='bus'||dosDown) return;
    if(dosLoad>0){
      dosLoad=Math.max(0,dosLoad-DOS_DECAY);
      updateGauge(); updateStatus();
      if(dosLoad===0) addLog('> LOAD CLEARED — NETWORK RECOVERED','ok');
    }
  },DOS_DECAY_MS);
}
function resetDecayTimer(){ clearInterval(dosDecayTimer); setTimeout(startDecay,900); }

/* ══════════════════════════════════════════════════
   GAUGE
══════════════════════════════════════════════════ */
function updateGauge(){
  const arc=document.getElementById('garc');
  const pct=document.getElementById('gpct');
  const gs=document.getElementById('gstatus');
  if(!arc) return;
  const total=151;
  arc.setAttribute('stroke-dashoffset',total-(dosLoad/100)*total);
  const col=dosLoad>=DOS_CRIT?cv('--red'):dosLoad>=DOS_WARN?cv('--yellow'):cv('--green');
  arc.setAttribute('stroke',col);
  pct.textContent=Math.round(dosLoad)+'%';
  pct.setAttribute('fill',cv('--orange'));
  document.getElementById('gpkts').textContent=dosSent;
  document.getElementById('gcoll').textContent=dosColl;
  document.getElementById('gdrop').textContent=dosDrop;
  if(dosDown||dosLoad>=DOS_DEAD){ gs.textContent='DEAD';     gs.className='gauge-status crit'; }
  else if(dosLoad>=DOS_CRIT)    { gs.textContent='CRITICAL'; gs.className='gauge-status crit'; }
  else if(dosLoad>=DOS_WARN)    { gs.textContent='WARNING';  gs.className='gauge-status warn'; }
  else                          { gs.textContent='NORMAL';   gs.className='gauge-status'; }
  setRV(dosDown?'[NETWORK DEAD]':`LOAD: ${Math.round(dosLoad)}%`);
  updateStatus();
}

/* ══════════════════════════════════════════════════
   STATUS
══════════════════════════════════════════════════ */
function updateStatus(){
  const dot=document.getElementById('sdot');
  const st=document.getElementById('stext');
  const dead=dosDown||switchBroken||(topo==='ring'&&cutSet.size>0)||(topo==='bus'&&dosLoad>=DOS_DEAD);
  const warn=dosLoad>=DOS_WARN&&dosLoad<DOS_DEAD;
  if(dead)      { dot.className='sdot fail';   st.textContent='FAILURE'; }
  else if(mitm) { dot.className='sdot purple'; st.textContent='COMPROMISED'; }
  else if(warn) { dot.className='sdot warn';   st.textContent='DEGRADED'; }
  else          { dot.className='sdot ok';     st.textContent='OPERATIONAL'; }
}

/* ══════════════════════════════════════════════════
   RESET
══════════════════════════════════════════════════ */
function resetAll(){
  clearInterval(dosDecayTimer); dosDecayTimer=null;
  cutSet.clear(); src=null; dst=null;
  mitm=false; switchBroken=false;
  dosLoad=0; dosSent=0; dosColl=0; dosDrop=0; dosDown=false;
  removeHammer(); removeHoverSc();
  const mb=document.getElementById('mitm-btn'); if(mb) mb.classList.remove('mitm-on');
  setRV('— select nodes —');
  draw(); updateStatus();
  if(topo==='bus'){ updateGauge(); startDecay(); }
  addLog('> NETWORK RESET — ALL SYSTEMS RESTORED','orange');
  doneTask(5);
}

/* ══════════════════════════════════════════════════
   CLEANUP HELPERS
══════════════════════════════════════════════════ */
function removeHammer(){
  const h=document.getElementById('hammer-ico');
  if(h){ clearInterval(h._bob); h.remove(); }
}
function removeHoverSc(){
  if(hoverScEl){ hoverScEl.remove(); hoverScEl=null; }
  const o=document.getElementById('hsc'); if(o) o.remove();
}

/* ══════════════════════════════════════════════════
   LOG
══════════════════════════════════════════════════ */
let lc=0;
function addLog(msg,type='info'){
  const el=document.getElementById('plog');
  const now=new Date();
  const ts=`${String(now.getHours()).padStart(2,'0')}:${String(now.getMinutes()).padStart(2,'0')}:${String(now.getSeconds()).padStart(2,'0')}`;
  const d=document.createElement('div');
  d.className=`le ${type}`; d.textContent=`[${ts}] ${msg}`;
  el.appendChild(d); el.scrollTop=el.scrollHeight;
  if(++lc>130) el.removeChild(el.firstChild);
}

/* ══════════════════════════════════════════════════
   TASKS
══════════════════════════════════════════════════ */
const taskDone=new Set();
function doneTask(n){
  if(taskDone.has(n)) return; taskDone.add(n);
  const el=document.getElementById(`t${n}`);
  if(el){ el.classList.remove('act'); el.classList.add('done'); }
  const nx=document.getElementById(`t${n+1}`);
  if(nx&&!taskDone.has(n+1)) nx.classList.add('act');
}

/* ══════════════════════════════════════════════════
   TOOLTIP
══════════════════════════════════════════════════ */
function showTip(e,msg){
  const t=document.getElementById('tip');
  t.style.display='block'; t.textContent=msg;
  const r=document.getElementById('svgwrap').getBoundingClientRect();
  t.style.left=(e.clientX-r.left+16)+'px';
  t.style.top=(e.clientY-r.top+16)+'px';
}
function hideTip(){ document.getElementById('tip').style.display='none'; }

/* ══════════════════════════════════════════════════
   INIT
══════════════════════════════════════════════════ */
window.addEventListener('DOMContentLoaded',()=>{ loadTopo('star'); });
window.addEventListener('resize',()=>draw());

/* Re-draw when theme changes (colors need refresh) */
const themeObserver=new MutationObserver(()=>draw());
themeObserver.observe(document.documentElement,{attributes:true,attributeFilter:['data-theme']});
</script>
