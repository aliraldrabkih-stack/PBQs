<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Topology Flaws Lab</title>
<style>
@import url('https://fonts.googleapis.com/css2?family=Share+Tech+Mono&family=Orbitron:wght@600;800&family=Rajdhani:wght@400;600;700&display=swap');

/* ══════════════════════════════════════════════════
   DARK THEME  (default / cyberpunk)
══════════════════════════════════════════════════ */
:root {
  --bg:            #060a0e;
  --bg2:           #0a1018;
  --surface:       #0d1520;
  --surface2:      #121e2e;
  --border:        #182535;
  --border2:       #223348;

  --orange:        #ff6a00;
  --orange2:       #ff8c00;
  --orange-dim:    #b84a00;
  --orange-glow:   rgba(255,106,0,.4);
  --orange-soft:   rgba(255,106,0,.09);
  --orange-pulse:  rgba(255,106,0,.18);

  --cyan:          #00d4ff;
  --cyan-soft:     rgba(0,212,255,.08);

  --green:         #00ff88;
  --green-dim:     #00883f;
  --red:           #ff2244;
  --red-dim:       #880022;
  --yellow:        #ffcc00;
  --purple:        #cc44ff;
  --purple-soft:   rgba(204,68,255,.1);

  --text:          #7a96b0;
  --text2:         #b0cce0;
  --heading:       #e4f2ff;
  --muted:         #2e4258;

  --scan-op:       .022;
  --grid-op:       .045;
  --node-fill:     #0a1828;
  --node-stroke:   #1e3a55;
  --link-color:    #152535;
  --link-ring:     #1a3a6a;
  --link-bus:      #1a4080;
  --gauge-track:   #0f1e2e;
  --sw-fill:       #0c1a2a;
  --tip-bg:        #0d1e30;
}

/* ══════════════════════════════════════════════════
   LIGHT THEME  — applied when html has [data-theme="light"]
   (set by JS via postMessage OR prefers-color-scheme)
══════════════════════════════════════════════════ */
html[data-theme="light"] {
  --bg:            #eef2f7;
  --bg2:           #e4eaf2;
  --surface:       #ffffff;
  --surface2:      #f5f8fc;
  --border:        #c8d8e8;
  --border2:       #aabdd0;

  --orange:        #c84a00;
  --orange2:       #dd6600;
  --orange-dim:    #923600;
  --orange-glow:   rgba(200,74,0,.22);
  --orange-soft:   rgba(200,74,0,.07);
  --orange-pulse:  rgba(200,74,0,.14);

  --cyan:          #0077aa;
  --cyan-soft:     rgba(0,119,170,.08);

  --green:         #007a38;
  --green-dim:     #004d22;
  --red:           #bb1133;
  --red-dim:       #880022;
  --yellow:        #aa7700;
  --purple:        #8800bb;
  --purple-soft:   rgba(136,0,187,.1);

  --text:          #4a6070;
  --text2:         #1e3040;
  --heading:       #080f18;
  --muted:         #99b0c4;

  --scan-op:       0;
  --grid-op:       .03;
  --node-fill:     #ddeeff;
  --node-stroke:   #aaccee;
  --link-color:    #c8dae8;
  --link-ring:     #aaccee;
  --link-bus:      #88aacc;
  --gauge-track:   #dde8f0;
  --sw-fill:       #e8f0fa;
  --tip-bg:        #ffffff;
}

/* ══════════════════════════════════════════════════
   BASE
══════════════════════════════════════════════════ */
*, *::before, *::after { box-sizing:border-box; margin:0; padding:0; }

html, body {
  height: 100%;
  transition: background .25s, color .25s;
}

body {
  background: var(--bg);
  color: var(--text2);
  font-family: 'Rajdhani', sans-serif;
  display: flex;
  flex-direction: column;
  overflow: hidden;
  position: relative;
}

/* cyberpunk grid */
body::before {
  content: '';
  position: fixed; inset: 0;
  background-image:
    linear-gradient(var(--border) 1px, transparent 1px),
    linear-gradient(90deg, var(--border) 1px, transparent 1px);
  background-size: 44px 44px;
  opacity: var(--grid-op);
  pointer-events: none;
  z-index: 0;
}

/* scanlines (dark only) */
body::after {
  content: '';
  position: fixed; inset: 0;
  background: repeating-linear-gradient(
    0deg, transparent, transparent 2px,
    rgba(0,0,0,.55) 2px, rgba(0,0,0,.55) 4px
  );
  opacity: var(--scan-op);
  pointer-events: none;
  z-index: 0;
}

.topbar, .lab { position: relative; z-index: 1; }

/* ══════════════════════════════════════════════════
   TOPBAR
══════════════════════════════════════════════════ */
.topbar {
  background: var(--surface);
  border-bottom: 1px solid var(--border);
  padding: 0 16px;
  height: 48px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  flex-shrink: 0;
  gap: 10px;
  box-shadow: 0 -3px 0 var(--orange) inset, 0 2px 24px rgba(0,0,0,.35);
}

.logo {
  font-family: 'Orbitron', monospace;
  font-size: 10.5px;
  font-weight: 800;
  color: var(--orange);
  white-space: nowrap;
  letter-spacing: .1em;
  text-shadow: 0 0 14px var(--orange-glow);
  text-transform: uppercase;
}
.logo span { color: var(--muted); font-weight: 600; }

.tabs { display: flex; gap: 2px; }
.tab {
  padding: 5px 12px;
  border-radius: 2px;
  font-size: 10.5px;
  font-weight: 700;
  letter-spacing: .07em;
  text-transform: uppercase;
  cursor: pointer;
  border: 1px solid transparent;
  color: var(--muted);
  font-family: 'Share Tech Mono', monospace;
  transition: all .15s;
}
.tab:hover { color: var(--text2); border-color: var(--border2); }
.tab.active {
  background: var(--orange-soft);
  border-color: var(--orange-dim);
  color: var(--orange);
  box-shadow: 0 0 10px var(--orange-glow);
}

.tbright { display: flex; gap: 6px; align-items: center; flex-shrink: 0; }

.tbtn {
  padding: 5px 12px;
  border-radius: 2px;
  font-size: 10.5px;
  font-weight: 700;
  letter-spacing: .06em;
  text-transform: uppercase;
  cursor: pointer;
  border: 1px solid var(--border2);
  background: transparent;
  color: var(--muted);
  font-family: 'Share Tech Mono', monospace;
  transition: all .15s;
  white-space: nowrap;
}
.tbtn:hover { border-color: var(--orange-dim); color: var(--orange); box-shadow: 0 0 8px var(--orange-glow); }
.tbtn.mitm-on {
  background: var(--purple-soft);
  border-color: var(--purple);
  color: var(--purple);
  box-shadow: 0 0 10px rgba(204,68,255,.35);
}
.tbtn.send-btn {
  border-color: var(--orange-dim);
  color: var(--orange);
  background: var(--orange-soft);
}
.tbtn.send-btn:hover { box-shadow: 0 0 14px var(--orange-glow); }

/* theme pill — shows current mode */
.theme-pill {
  display: flex;
  align-items: center;
  gap: 5px;
  padding: 4px 10px;
  border-radius: 20px;
  border: 1px solid var(--border2);
  font-family: 'Share Tech Mono', monospace;
  font-size: 9.5px;
  letter-spacing: .07em;
  text-transform: uppercase;
  color: var(--muted);
  cursor: pointer;
  transition: all .2s;
  user-select: none;
}
.theme-pill:hover { border-color: var(--orange-dim); color: var(--orange); }
.theme-pill .tpicon { font-size: 12px; }
.theme-pill .tplabel { font-size: 9px; }

/* ══════════════════════════════════════════════════
   LAYOUT
══════════════════════════════════════════════════ */
.lab { display: flex; flex: 1; overflow: hidden; min-height: 0; }

/* ══════════════════════════════════════════════════
   SIDEBAR
══════════════════════════════════════════════════ */
.sb {
  width: 198px;
  background: var(--surface);
  border-right: 1px solid var(--border);
  display: flex;
  flex-direction: column;
  flex-shrink: 0;
  overflow: hidden;
  /* orange left accent */
  box-shadow: 3px 0 0 var(--orange) inset;
}

.sb-sec {
  padding: 8px 14px 3px;
  font-size: 9px;
  font-weight: 700;
  letter-spacing: .14em;
  text-transform: uppercase;
  color: var(--orange-dim);
  font-family: 'Share Tech Mono', monospace;
}

.sb-item {
  padding: 7px 14px;
  font-size: 11.5px;
  font-weight: 600;
  color: var(--muted);
  display: flex;
  align-items: center;
  gap: 8px;
  border-left: 3px solid transparent;
  transition: all .2s;
  letter-spacing: .02em;
}
.sb-item.act {
  color: var(--orange);
  border-left-color: var(--orange);
  background: var(--orange-soft);
  text-shadow: 0 0 8px var(--orange-glow);
}
.sb-item.done { color: var(--green); border-left-color: var(--green-dim); }

.dot {
  width: 6px; height: 6px;
  border-radius: 50%;
  background: var(--border2);
  flex-shrink: 0;
  transition: all .2s;
}
.sb-item.act  .dot { background: var(--orange); box-shadow: 0 0 6px var(--orange); }
.sb-item.done .dot { background: var(--green); box-shadow: 0 0 4px var(--green); }

.flaw-box {
  flex: 1;
  padding: 10px 14px;
  font-size: 11px;
  color: var(--text);
  line-height: 1.8;
  border-top: 1px solid var(--border);
  overflow-y: auto;
}
.flaw-box b { color: var(--orange); }

/* ══════════════════════════════════════════════════
   CANVAS
══════════════════════════════════════════════════ */
.cvs { flex: 1; display: flex; flex-direction: column; overflow: hidden; min-width: 0; }

.cvs-head {
  padding: 10px 18px;
  border-bottom: 1px solid var(--border);
  flex-shrink: 0;
  background: var(--surface2);
}
.cvs-title {
  font-family: 'Orbitron', monospace;
  font-size: 13px;
  font-weight: 600;
  color: var(--orange);
  letter-spacing: .06em;
  text-shadow: 0 0 10px var(--orange-glow);
}
.cvs-desc {
  font-size: 11.5px;
  color: var(--text);
  margin-top: 3px;
  line-height: 1.55;
  font-weight: 400;
}
.flaw-badge {
  display: inline-flex;
  align-items: center;
  gap: 4px;
  padding: 2px 10px;
  border-radius: 2px;
  font-size: 9.5px;
  font-weight: 700;
  letter-spacing: .07em;
  text-transform: uppercase;
  margin-top: 6px;
  font-family: 'Share Tech Mono', monospace;
}
.flaw-badge.red    { background: rgba(255,34,68,.08); border: 1px solid rgba(255,34,68,.35); color: var(--red); }
.flaw-badge.orange { background: var(--orange-soft);   border: 1px solid var(--orange-dim);   color: var(--orange); }
.flaw-badge.purple { background: var(--purple-soft);   border: 1px solid var(--purple);       color: var(--purple); }

.svgwrap { flex: 1; position: relative; overflow: hidden; background: var(--bg2); }
svg#msv { width: 100%; height: 100%; }

.tip {
  position: absolute;
  background: var(--tip-bg);
  border: 1px solid var(--orange-dim);
  border-radius: 2px;
  padding: 5px 10px;
  font-size: 10.5px;
  font-family: 'Share Tech Mono', monospace;
  color: var(--orange);
  pointer-events: none;
  z-index: 999;
  display: none;
  white-space: nowrap;
  box-shadow: 0 0 10px var(--orange-glow);
}

/* ══════════════════════════════════════════════════
   DoS GAUGE
══════════════════════════════════════════════════ */
.gauge-overlay {
  position: absolute;
  bottom: 16px;
  left: 50%;
  transform: translateX(-50%);
  display: none;
  align-items: flex-end;
  gap: 14px;
  background: var(--surface);
  border: 1px solid var(--border2);
  border-top: 2px solid var(--orange-dim);
  border-radius: 4px;
  padding: 12px 18px;
  box-shadow: 0 0 20px rgba(0,0,0,.5), 0 0 14px var(--orange-glow);
}
.gauge-col { display: flex; flex-direction: column; align-items: center; gap: 5px; }
.gauge-label {
  font-size: 9px; font-weight: 700; letter-spacing: .12em;
  text-transform: uppercase; color: var(--orange-dim);
  font-family: 'Share Tech Mono', monospace;
}
.gauge-status {
  font-family: 'Share Tech Mono', monospace;
  font-size: 10.5px;
  padding: 3px 10px;
  border-radius: 2px;
  background: rgba(0,255,136,.08);
  border: 1px solid rgba(0,255,136,.3);
  color: var(--green);
  letter-spacing: .08em;
}
.gauge-status.warn { background: rgba(255,204,0,.08); border-color: rgba(255,204,0,.35); color: var(--yellow); }
.gauge-status.crit {
  background: rgba(255,34,68,.1); border-color: rgba(255,34,68,.45); color: var(--red);
  animation: cb .45s infinite;
}
.gauge-hint {
  font-size: 9px; color: var(--muted);
  font-family: 'Share Tech Mono', monospace;
  text-align: center; letter-spacing: .04em;
}
@keyframes cb { 0%,100%{opacity:1} 50%{opacity:.25} }

/* ══════════════════════════════════════════════════
   RIGHT PANEL
══════════════════════════════════════════════════ */
.rp {
  width: 242px;
  background: var(--surface);
  border-left: 1px solid var(--border);
  display: flex;
  flex-direction: column;
  flex-shrink: 0;
  box-shadow: -3px 0 0 var(--orange-dim) inset;
}

.rp-sec {
  padding: 10px 13px;
  border-bottom: 1px solid var(--border);
}
.rp-label {
  font-size: 9px;
  font-weight: 700;
  letter-spacing: .13em;
  text-transform: uppercase;
  color: var(--orange-dim);
  margin-bottom: 5px;
  font-family: 'Share Tech Mono', monospace;
}
.rp-val {
  font-size: 12px;
  color: var(--heading);
  font-family: 'Share Tech Mono', monospace;
}

.sdot {
  display: inline-block;
  width: 7px; height: 7px;
  border-radius: 50%;
  margin-right: 6px;
  transition: all .3s;
}
.sdot.ok     { background: var(--green);  box-shadow: 0 0 6px var(--green); }
.sdot.warn   { background: var(--yellow); box-shadow: 0 0 6px var(--yellow); }
.sdot.fail   { background: var(--red);    box-shadow: 0 0 6px var(--red); }
.sdot.purple { background: var(--purple); box-shadow: 0 0 6px var(--purple); }

.log {
  flex: 1;
  overflow-y: auto;
  padding: 7px 11px;
  font-family: 'Share Tech Mono', monospace;
  font-size: 10px;
  line-height: 1.95;
  min-height: 0;
  background: var(--bg2);
}
/* custom scrollbar */
.log::-webkit-scrollbar { width: 4px; }
.log::-webkit-scrollbar-track { background: var(--bg2); }
.log::-webkit-scrollbar-thumb { background: var(--border2); border-radius: 2px; }

.le        { margin-bottom: 1px; }
.le.ok     { color: var(--green); }
.le.fail   { color: var(--red); }
.le.warn   { color: var(--yellow); }
.le.info   { color: var(--muted); }
.le.mitm   { color: var(--purple); }
.le.orange { color: var(--orange); }

.act-area {
  padding: 10px 13px;
  border-top: 1px solid var(--border);
  flex-shrink: 0;
}
.abtn {
  padding: 8px 12px;
  border-radius: 2px;
  font-size: 10.5px;
  font-weight: 700;
  letter-spacing: .07em;
  text-transform: uppercase;
  cursor: pointer;
  border: 1px solid var(--orange-dim);
  background: var(--orange-soft);
  color: var(--orange);
  font-family: 'Share Tech Mono', monospace;
  width: 100%;
  transition: all .15s;
}
.abtn:hover { box-shadow: 0 0 12px var(--orange-glow); background: var(--orange-pulse); }

/* corner decorations — cyberpunk brackets */
.cvs-head::before {
  content: '';
  display: block;
  position: absolute;
  width: 8px; height: 8px;
  border-top: 2px solid var(--orange);
  border-left: 2px solid var(--orange);
  left: 0; top: 0;
  opacity: .6;
}
</style>
</head>
<body>

<!-- TOPBAR -->
<div class="topbar">
  <div style="display:flex;align-items:center;gap:10px;">
    <div class="logo">⬡ <span>NET /</span> TOPOLOGIES</div>
    <div class="tabs">
      <div class="tab active" onclick="loadTopo('star')">★ STAR</div>
      <div class="tab" onclick="loadTopo('bus')">▬ BUS</div>
      <div class="tab" onclick="loadTopo('ring')">◎ RING</div>
    </div>
  </div>
  <div class="tbright" id="tbright">
    <!-- theme pill + action buttons injected here -->
    <div class="theme-pill" id="theme-pill" onclick="manualToggle()" title="Toggle theme">
      <span class="tpicon" id="tpicon">🌙</span>
      <span class="tplabel" id="tplabel">DARK</span>
    </div>
  </div>
</div>

<!-- BODY -->
<div class="lab">

  <!-- SIDEBAR -->
  <div class="sb">
    <div class="sb-sec">// TASKS</div>
    <div class="sb-item act" id="t1"><div class="dot"></div><span id="t1l">—</span></div>
    <div class="sb-item"     id="t2"><div class="dot"></div><span id="t2l">—</span></div>
    <div class="sb-item"     id="t3"><div class="dot"></div><span id="t3l">—</span></div>
    <div class="sb-item"     id="t4"><div class="dot"></div><span id="t4l">—</span></div>
    <div class="sb-item"     id="t5"><div class="dot"></div><span id="t5l">Reset & retry</span></div>
    <div class="flaw-box" id="flaw-box">—</div>
  </div>

  <!-- CANVAS -->
  <div class="cvs">
    <div class="cvs-head" style="position:relative;">
      <div class="cvs-title" id="ctitle">—</div>
      <div class="cvs-desc"  id="cdesc">—</div>
      <div class="flaw-badge orange" id="cflaw">—</div>
    </div>
    <div class="svgwrap" id="svgwrap">
      <svg id="msv"></svg>
      <div class="tip" id="tip"></div>

      <!-- DoS Gauge (Bus only) -->
      <div class="gauge-overlay" id="gauge">
        <div class="gauge-col">
          <div class="gauge-label">// Network Load</div>
          <svg width="122" height="70" viewBox="0 0 122 70">
            <path d="M13,66 A48,48 0 0,1 109,66" fill="none" stroke="var(--gauge-track)" stroke-width="11" stroke-linecap="round"/>
            <path id="garc" d="M13,66 A48,48 0 0,1 109,66" fill="none" stroke="var(--green)" stroke-width="11" stroke-linecap="round"
              stroke-dasharray="151" stroke-dashoffset="151" style="transition:stroke-dashoffset .22s,stroke .22s"/>
            <circle cx="61" cy="66" r="4" fill="var(--surface2)"/>
            <text id="gpct" x="61" y="53" text-anchor="middle"
              font-family="'Share Tech Mono',monospace" font-size="17" font-weight="700" fill="var(--orange)">0%</text>
          </svg>
          <div class="gauge-status" id="gstatus">NORMAL</div>
          <div class="gauge-hint">SPAM ▶ FAST TO FLOOD · SLOW TO RECOVER</div>
        </div>
        <div class="gauge-col" style="gap:7px;padding-left:12px;border-left:1px solid var(--border2);">
          <div style="font-size:9px;color:var(--orange-dim);font-weight:700;letter-spacing:.1em;font-family:'Share Tech Mono',monospace;">STATS</div>
          <div style="font-family:'Share Tech Mono',monospace;font-size:10.5px;color:var(--muted);">SENT&nbsp; <span id="gpkts" style="color:var(--heading)">0</span></div>
          <div style="font-family:'Share Tech Mono',monospace;font-size:10.5px;color:var(--muted);">COLL&nbsp; <span id="gcoll" style="color:var(--yellow)">0</span></div>
          <div style="font-family:'Share Tech Mono',monospace;font-size:10.5px;color:var(--muted);">DROP&nbsp; <span id="gdrop" style="color:var(--red)">0</span></div>
        </div>
      </div>
    </div>
  </div>

  <!-- RIGHT PANEL -->
  <div class="rp">
    <div class="rp-sec">
      <div class="rp-label">// Status</div>
      <div class="rp-val"><span class="sdot ok" id="sdot"></span><span id="stext">OPERATIONAL</span></div>
    </div>
    <div class="rp-sec">
      <div class="rp-label" id="rlabel">// Route</div>
      <div class="rp-val" id="routeval">— select nodes —</div>
    </div>
    <div class="rp-sec"><div class="rp-label">// Packet Log</div></div>
    <div class="log" id="plog"><div class="le info">// system ready_</div></div>
    <div class="act-area"><button class="abtn" onclick="resetAll()">↺ RESET NETWORK</button></div>
  </div>

</div>

<script>
/* ══════════════════════════════════════════════════
   THEME ENGINE
   Priority: postMessage > localStorage > prefers-color-scheme
══════════════════════════════════════════════════ */
(function initTheme(){
  function applyTheme(t){
    document.documentElement.setAttribute('data-theme', t);
    const icon  = document.getElementById('tpicon');
    const label = document.getElementById('tplabel');
    if(icon)  icon.textContent  = t==='dark' ? '🌙' : '☀️';
    if(label) label.textContent = t==='dark' ? 'DARK' : 'LIGHT';
    try{ localStorage.setItem('topo-theme', t); } catch(e){}
  }

  // 1. Listen for postMessage from parent site
  //    Expected format: { type: 'setTheme', theme: 'dark'|'light' }
  //    OR: { type: 'setTheme', dark: true|false }
  window.addEventListener('message', (e)=>{
    const d = e.data;
    if(!d || d.type !== 'setTheme') return;
    const t = d.theme || (d.dark === false ? 'light' : d.dark === true ? 'dark' : null);
    if(t === 'dark' || t === 'light') applyTheme(t);
  });

  // 2. Listen for OS-level changes (prefers-color-scheme)
  const mq = window.matchMedia('(prefers-color-scheme: dark)');
  mq.addEventListener('change', (e)=>{
    // only follow OS if no manual override saved
    if(!localStorage.getItem('topo-theme-manual')){
      applyTheme(e.matches ? 'dark' : 'light');
    }
  });

  // 3. Initial: check localStorage override first, then OS
  try {
    const saved = localStorage.getItem('topo-theme');
    if(saved === 'dark' || saved === 'light'){
      applyTheme(saved); return;
    }
  } catch(e){}
  applyTheme(mq.matches ? 'dark' : 'light');
})();

// Manual toggle from the pill button
function manualToggle(){
  const cur = document.documentElement.getAttribute('data-theme') || 'dark';
  const next = cur === 'dark' ? 'light' : 'dark';
  document.documentElement.setAttribute('data-theme', next);
  const icon  = document.getElementById('tpicon');
  const label = document.getElementById('tplabel');
  if(icon)  icon.textContent  = next==='dark' ? '🌙' : '☀️';
  if(label) label.textContent = next==='dark' ? 'DARK' : 'LIGHT';
  try{
    localStorage.setItem('topo-theme', next);
    localStorage.setItem('topo-theme-manual','1');
  } catch(e){}
  // Notify parent if embedded in an iframe
  try{ window.parent.postMessage({ type:'themeChanged', theme:next }, '*'); } catch(e){}
}

