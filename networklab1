/* ══════════════════════════════════════════════════
   HELPERS
══════════════════════════════════════════════════ */
function lid(a,b){return [a,b].sort().join('~~');}
function getNode(id){return nodes.find(n=>n.id===id);}
function $s(t){return document.createElementNS('http://www.w3.org/2000/svg',t);}
function sa(el,at){Object.entries(at).forEach(([k,v])=>el.setAttribute(k,v));}
function setRV(v){const e=document.getElementById('routeval');if(e)e.textContent=v;}

/* ══════════════════════════════════════════════════
   LOAD TOPOLOGY
══════════════════════════════════════════════════ */
function loadTopo(name){
  topo=name; cutSet.clear(); src=null; dst=null;
  mitm=false; switchBroken=false;
  dosLoad=0; dosSent=0; dosColl=0; dosDrop=0; dosDown=false;
  hoverScEl=null;
  clearInterval(dosDecayTimer); dosDecayTimer=null;

  const def=DEFS[name];
  nodes=def.nodes.map(n=>({...n}));
  links=def.links.map(l=>({...l}));

  document.getElementById('ctitle').textContent=def.title;
  document.getElementById('cdesc').textContent=def.desc;
  const fb=document.getElementById('cflaw');
  fb.textContent=def.flaw; fb.className='flaw-badge '+def.flawClass;
  document.getElementById('flaw-box').innerHTML=def.flawInfo;

  def.tasks.forEach((txt,i)=>{
    const s=document.getElementById(`t${i+1}l`); if(s) s.textContent=txt;
    const el=document.getElementById(`t${i+1}`); if(el) el.className='sb-item'+(i===0?' act':'');
  });
  taskDone.clear();

  document.querySelectorAll('.tab').forEach(t=>{
    const m={star:'STAR',bus:'BUS',ring:'RING'};
    t.classList.toggle('active',t.textContent.includes(m[name]));
  });

  document.getElementById('rlabel').textContent=name==='bus'?'// DoS Load':'// Route';
  setRV('— select nodes —');
  buildToolbar(name);
  document.getElementById('gauge').style.display=name==='bus'?'flex':'none';
  if(name==='bus'){ updateGauge(); startDecay(); }

  draw(); updateStatus();
  addLog(`> LOADED: ${def.title}`,'orange');
}

